# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Runtime ---
ENV=development
# Set to "production" to activate the production safety guard (blocks AI/voice flags if any are true).

# --- Database ---
DATABASE_URL=postgresql+psycopg://clerk:clerk@localhost:5432/clerk
STORAGE_DIR=storage

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://ollama:11434
LLM_PROVIDER=ollama
# Set LLM_PROVIDER=stub to skip all LLM calls (pure deterministic mode).

# --- Embeddings ---
EMBED_PROVIDER=fastembed
EMBEDDING_DIM=384

# --- Command API feature flags (all off by default) ---
ENABLE_COMMAND_API=false
ENABLE_VOICE_INPUT=false
ENABLE_DEBUG_ROUTES=false

# --- Intent extraction ---
COMMAND_INTENT_USE_LLM=false
# When false: deterministic rule-based parser (no Ollama needed, 100% tested).
# When true: Ollama Llama 3 8B with rule-based fallback.
COMMAND_INTENT_HEALTH_TIMEOUT_S=1.0

# --- Content transform ---
COMMAND_TRANSFORM_USE_LLM=false
# When false: deterministic stub (prepend/clip/canned text).
# When true: Ollama Llama 3 8B rewrite with repair fallback.
COMMAND_TRANSFORM_HEALTH_TIMEOUT_S=1.0

# --- STT ---
# faster_whisper  — CPU/CUDA via CTranslate2 (works in Docker, Linux, GPU servers)
# mlx_whisper     — Metal GPU via MLX (Apple M-series only; 3-5x faster than CPU on M4)
STT_PROVIDER=faster_whisper
STT_MODEL_NAME=large-v3-turbo
STT_DEVICE=cpu
# Options: cpu | cuda | auto  (ignored when STT_PROVIDER=mlx_whisper)
STT_COMPUTE_TYPE=int8
# CPU: int8  |  GPU CUDA: float16  |  mlx_whisper: set in mlx config (ignored here)
STT_MIN_CONFIDENCE=0.25
# Below this threshold: could_not_understand_audio error
STT_CONFIRM_CONFIDENCE=0.45
# Below this threshold (but above min): needs_clarification with transcript shown
STT_HEALTH_TIMEOUT_S=10.0
# STT_FORCE_LANGUAGE=hi
# Uncomment to force language detection (e.g. hi=Hindi, en=English).

# --- Misc ---
AUTO_BOOTSTRAP=false
# Set to true to auto-run DB init + template registration on first startup.
